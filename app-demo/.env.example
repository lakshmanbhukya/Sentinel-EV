# ============================================
# EV Charging Demand Analytics - Frontend Configuration
# ============================================

# Backend API Configuration
# --------------------------

# VITE_API_BASE_URL: The base URL for the Express backend API
# This should point to where your backend server is running.
# Default: http://localhost:3000/api
# Production: Update this to your production backend URL
VITE_API_BASE_URL=http://localhost:3000/api

# VITE_DISABLE_BACKEND: Force the frontend to use mock data instead of the backend
# Set to 'true' to disable backend API calls and always use mock data.
# Set to 'false' or leave unset to enable backend integration.
# Useful for:
#   - Development when backend is not available
#   - Testing frontend-only features
#   - Demos without backend dependency
# Default: false
VITE_DISABLE_BACKEND=false

# OpenCharge Map API Configuration
# ---------------------------------

# VITE_OCM_API_KEY: API key for OpenCharge Map (openchargemap.org)
# Note: This is primarily for reference. The backend handles OpenCharge API calls.
# The frontend does not directly call the OpenCharge API.
# Get your API key from: https://openchargemap.org/site/profile/applications
VITE_OCM_API_KEY=YOUR_API_KEY

# ============================================
# Setup Instructions
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update VITE_API_BASE_URL if your backend runs on a different port
# 3. Set VITE_DISABLE_BACKEND=true if you want to use mock data only
# 4. The OpenCharge API key should be configured in the backend .env file
# 5. Start the backend first: cd Backend && npm run dev
# 6. Then start the frontend: npm run dev
# 7. Check browser console for connection status logs
